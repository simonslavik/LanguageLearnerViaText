# ── Application ────────────────────────────────────────────────────────────
# Change to a long random string in production (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string

# ── MongoDB ────────────────────────────────────────────────────────────────
# When running via docker compose this is overridden to mongodb://mongo:27017
MONGO_URL=mongodb://localhost:27017
MONGO_DB=translation_app

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-too
JWT_EXPIRE_MINUTES=60

# ── Google OAuth ───────────────────────────────────────────────────────────
# Leave blank to disable the Google login button
GOOGLE_CLIENT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (used at Docker build time) ──────────────────────────────────
# Pass to docker compose: VITE_GOOGLE_CLIENT_ID=... docker compose up
VITE_GOOGLE_CLIENT_ID=
